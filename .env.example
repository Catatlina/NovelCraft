# ============================================================
# 星禾写作助手 — 环境变量配置示例
# ============================================================
# 使用方法：
#   1. 复制这个文件，改名为 .env    （Linux/Mac: cp .env.example .env）
#   2. 按下面每一项的说明，把 <尖括号> 里的内容替换成你自己的真实值
#   3. 不要把改好的 .env 文件分享给任何人、也不要提交到 git 仓库
#
# 完整的生成步骤请看《部署文档》第三步，这里只做变量本身的说明。
# ============================================================


# ---------------- 数据库 ----------------
# 数据库用户名，一般不需要改，保持默认即可
DB_USER=novelcraft

# 数据库密码：必须自己设置一个强密码，不能留空，否则容器启动不了
# 生成方法（终端里执行）：openssl rand -base64 24
DB_PASSWORD=<在这里填一个你自己生成的强密码>

# 数据库名，一般不需要改
DB_NAME=novelcraft


# ---------------- Redis ----------------
# Redis 密码：必须自己设置一个强密码，不能留空
# 生成方法：openssl rand -base64 24
REDIS_PASSWORD=<在这里填一个你自己生成的强密码>


# ---------------- 登录认证 ----------------
# JWT 签名密钥：用来给登录令牌签名，必须是随机生成的一长串字符，不能留空
# 生成方法：python3 -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=<在这里填一个你自己生成的随机密钥>

# 系统管理员账号的用户名（首次启动时会自动创建这个账号）
ADMIN_USERNAME=admin

# 系统管理员账号的密码：必须自己设置，不能留空，建议设置得复杂一些
ADMIN_PASSWORD=<在这里填一个你自己设置的管理员密码>


# ---------------- AI 模型 (DeepSeek) ----------------
# DeepSeek API Key：去 https://platform.deepseek.com 注册账号后，在
# "API Keys" 页面创建一个，粘贴到这里。没有这个，AI 写作/审查/翻译等
# 全部功能都无法使用。
DEEPSEEK_API_KEY=<在这里填你的DeepSeek API Key>

# 以下两项一般不需要改，保持默认即可
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat


# ---------------- 平台账号加密（可选） ----------------
# 只有当你要使用"平台账号绑定/自动发布"功能时才需要配置这一项。
# 如果你暂时不用这个功能，可以先留空，用到的时候再回来配置。
# 生成方法：python3 -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# 注意：配置好之后不要再改动这个值，否则之前加密保存的平台账号信息会全部无法解密。
ACCOUNT_ENCRYPTION_KEY=


# ---------------- 跨域配置 ----------------
# 如果你是在自己电脑上本地体验，不需要改这一项，保持默认即可。
# 如果你要把这个系统部署到一台云服务器上，正式对外提供服务，把下面这行
# 换成你实际访问前端网页时用的地址，例如：
#   CORS_ORIGINS=https://your-domain.com
# 多个地址用英文逗号隔开，不要有空格。
CORS_ORIGINS=http://localhost:8080,http://localhost:3000,http://localhost:5173


# Cookie 安全策略
# 生产 HTTPS 建议设置 true；本地 HTTP 开发保持 false。
COOKIE_SECURE=false
# 可选 lax/strict/none。跨站 cookie 必须 none 且 COOKIE_SECURE=true。
COOKIE_SAMESITE=lax
