# NovelCraft v7.0 — 环境变量模板
# 复制此文件为 .env 并填入真实值

# 数据库连接
database_url=postgresql+asyncpg://novelcraft:novelcraft123@localhost:5432/novelcraft_v7

# 安全（请生成随机密钥: python3 -c "import secrets; print(secrets.token_urlsafe(32))"）
secret_key=change-me-to-a-random-string

# DeepSeek API (必需，从 https://platform.deepseek.com 获取)
deepseek_api_key=sk-your-key-here
deepseek_base_url=https://api.deepseek.com
deepseek_model=deepseek-chat

# 管理员（首次启动自动创建）
admin_username=admin
admin_password=change-me

# Redis (Celery 任务队列)
redis_url=redis://localhost:6379/0

# Playwright 发布 (可选)
# WEBOVEL_EMAIL=     WEBOVEL_PASSWORD=
# ROYALROAD_EMAIL=   ROYALROAD_PASSWORD=
# WATTPAD_EMAIL=     WATTPAD_PASSWORD=
