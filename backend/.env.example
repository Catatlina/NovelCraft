# NovelCraft v7.0 — 环境变量模板
# 复制此文件为 .env 并填入真实值

# 数据库连接
database_url=postgresql+asyncpg://novelcraft:<DB_PASSWORD>@localhost:5432/novelcraft

# Docker Compose 专用：db 服务与 api/worker 服务共用同一组变量生成各自的 DATABASE_URL，
# 修改这里的密码后 api/worker 会自动使用新密码连接，不需要再单独改 docker-compose.yml
DB_USER=novelcraft
DB_PASSWORD=<生成一个强密码>
DB_NAME=novelcraft

# 平台账号凭证加密密钥（使用平台发布自动化功能时必须设置，且设置后不可更改，
# 否则历史加密凭证将无法解密）
# 生成方法: python3 -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
account_encryption_key=

# 安全（请生成随机密钥: python3 -c "import secrets; print(secrets.token_urlsafe(32))"）
secret_key=<python3 -c "import secrets; print(secrets.token_urlsafe(32))" 生成>

# DeepSeek API (必需，从 https://platform.deepseek.com 获取)
deepseek_api_key=sk-your-key-here
deepseek_base_url=https://api.deepseek.com
deepseek_model=deepseek-chat

# 管理员（首次启动自动创建）
admin_username=admin
admin_password=<设置一个强管理员密码>

# Redis (Celery 任务队列)
REDIS_PASSWORD=<生成一个强密码>
redis_url=redis://:<REDIS_PASSWORD>@localhost:6379/0

# Playwright 发布 (可选)
# WEBOVEL_EMAIL=     WEBOVEL_PASSWORD=
# ROYALROAD_EMAIL=   ROYALROAD_PASSWORD=
# WATTPAD_EMAIL=     WATTPAD_PASSWORD=


# Cookie 安全策略
# 生产 HTTPS 建议设置 true；本地 HTTP 开发保持 false。
COOKIE_SECURE=false
# 可选 lax/strict/none。跨站 cookie 必须 none 且 COOKIE_SECURE=true。
COOKIE_SAMESITE=lax
